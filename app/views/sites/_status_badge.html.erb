<%
  colors = {
    "up"      => "background: #dcfce7; color: #166534;",
    "down"    => "background: #fee2e2; color: #991b1b;",
    "unknown" => "background: #f3f4f6; color: #6b7280;"
  }
  style = colors.fetch(status, colors["unknown"])
%>
<span style="<%= style %> padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 600;">
  <%= status %>
</span>
