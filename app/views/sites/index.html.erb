<% content_for(:title) { "Sites — Dorm Guard" } %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold">Monitored Sites</h1>
  <%= link_to "New site", new_site_path, class: "btn btn-primary" %>
</div>

<% if @sites.any? %>
  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>Name</th>
          <th>URL</th>
          <th>Status</th>
          <th>Last Checked</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @sites.each do |site| %>
          <tr>
            <td class="font-medium"><%= site.name %></td>
            <td>
              <%= link_to site.url, site.url,
                    target: "_blank",
                    rel: "noopener noreferrer",
                    class: "link link-hover" %>
            </td>
            <td>
              <%= render(StatusBadgeComponent.new(status: site.status)) %>
            </td>
            <td class="text-base-content/70">
              <% if site.last_checked_at %>
                <%= time_ago_in_words(site.last_checked_at) %> ago
              <% else %>
                Never
              <% end %>
            </td>
            <td>
              <div class="flex gap-2 justify-end">
                <%= link_to "Show", site_path(site), class: "btn btn-ghost btn-sm" %>
                <%= link_to "Edit", edit_site_path(site), class: "btn btn-ghost btn-sm" %>
                <%= render(DeleteButtonComponent.new(site: site)) %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render(PagyNavComponent.new(pagy: @pagy)) %>
<% else %>
  <p class="text-base-content/70 py-8">
    No sites monitored yet. Click <strong>New site</strong> to add the first one.
  </p>
<% end %>
