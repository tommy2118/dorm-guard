<% content_for(:title) { "Sites — Dorm Guard" } %>

<h1 class="text-2xl font-semibold mb-6">Monitored Sites</h1>

<% if @sites.any? %>
  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>Name</th>
          <th>URL</th>
          <th>Status</th>
          <th>Last Checked</th>
        </tr>
      </thead>
      <tbody>
        <% @sites.each do |site| %>
          <tr>
            <td class="font-medium"><%= site.name %></td>
            <td>
              <%= link_to site.url, site.url,
                    target: "_blank",
                    rel: "noopener noreferrer",
                    class: "link link-hover" %>
            </td>
            <td>
              <%= render(StatusBadgeComponent.new(status: site.status)) %>
            </td>
            <td class="text-base-content/70">
              <% if site.last_checked_at %>
                <%= time_ago_in_words(site.last_checked_at) %> ago
              <% else %>
                Never
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-base-content/70 py-8">
    No sites monitored yet. Add some via <code>db/seeds.rb</code> and run
    <code>bin/dc bin/rails db:seed</code>.
  </p>
<% end %>
