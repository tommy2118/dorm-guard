<% content_for(:title) { "Sites — Dorm Guard" } %>

<div style="max-width: 960px; margin: 0 auto; padding: 2rem 1rem;">
  <h1 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">
    Monitored Sites
  </h1>

  <% if @sites.any? %>
    <table style="width: 100%; border-collapse: collapse; font-size: 0.95rem;">
      <thead>
        <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
          <th style="padding: 0.75rem 0.5rem;">Name</th>
          <th style="padding: 0.75rem 0.5rem;">URL</th>
          <th style="padding: 0.75rem 0.5rem;">Status</th>
          <th style="padding: 0.75rem 0.5rem;">Last Checked</th>
        </tr>
      </thead>
      <tbody>
        <% @sites.each do |site| %>
          <tr style="border-bottom: 1px solid #f3f4f6;">
            <td style="padding: 0.75rem 0.5rem; font-weight: 500;"><%= site.name %></td>
            <td style="padding: 0.75rem 0.5rem; color: #6b7280;">
              <%= link_to site.url, site.url, target: "_blank", rel: "noopener noreferrer" %>
            </td>
            <td style="padding: 0.75rem 0.5rem;">
              <%= render partial: "sites/status_badge", locals: { status: site.status } %>
            </td>
            <td style="padding: 0.75rem 0.5rem; color: #6b7280;">
              <% if site.last_checked_at %>
                <%= time_ago_in_words(site.last_checked_at) %> ago
              <% else %>
                Never
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #6b7280; padding: 2rem 0;">
      No sites monitored yet. Add some via <code>db/seeds.rb</code> and run
      <code>bin/dc bin/rails db:seed</code>.
    </p>
  <% end %>
</div>
