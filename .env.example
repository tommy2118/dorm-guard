# .env.example — dorm-guard production deploy contract
#
# Copy to `.env` (gitignored) on the operator's workstation and fill in
# values before running `bin/dc bin/kamal deploy`. The `.kamal/secrets`
# file sources this same `.env` in CI via the deploy workflow, so the
# schema must stay identical across laptop and CI.
#
# Rule (see memory: feedback_enforce_constraints_in_config):
#   A required deploy var landing in `config/deploy.yml` without a
#   corresponding line in this file is a process violation.
#
# This file is the shared contract. Each Kamal-deploy slice extends it
# with the vars the slice introduces:
#   Slice 1 — seeds this file with vars already consumed by the code
#   Slice 2A — adds DORM_GUARD_HOST
#   Slice 2B — adds MAILGUN_SMTP_* SMTP credentials
#   Slice 3  — adds DORM_GUARD_MAIL_FROM
#   Slice 4  — adds KAMAL_REGISTRY_PASSWORD + any remaining keys

# --- Already consumed by the current codebase ---------------------------

# Rails message verifier / credentials key. Sourced from config/master.key
# on the operator's laptop via `.kamal/secrets`; provided directly in CI.
RAILS_MASTER_KEY=

# Recipient address for DowntimeAlertMailer. Read in:
#   app/mailers/downtime_alert_mailer.rb
# Default in code is `alerts@dorm-guard.local` — override in production.
DORM_GUARD_ALERT_TO=

# --- Slice 2A: public hostname -----------------------------------------

# Public hostname the app is served from. Drives:
#   - config/environments/production.rb:hosts allowlist (DNS rebinding)
#   - config/environments/production.rb:default_url_options (mailer URLs)
# Default in code is "dorm-guard.com". Must match the Kamal proxy host
# in config/deploy.yml so Let's Encrypt issues a cert for this name.
DORM_GUARD_HOST=

# --- Slice 2B / 5B: SMTP credentials (provider-neutral) ---------------

# SMTP host and port. Default in code is email-smtp.us-east-1.amazonaws.com:587
# (Amazon SES, STARTTLS + AUTH LOGIN). Override SMTP_ADDRESS to switch
# regions or providers without touching config/deploy.yml or code:
#   - SES us-west-2:   email-smtp.us-west-2.amazonaws.com
#   - SES eu-west-1:   email-smtp.eu-west-1.amazonaws.com
#   - Resend:          smtp.resend.com
#   - Mailgun EU:      smtp.eu.mailgun.org
SMTP_ADDRESS=
SMTP_PORT=

# SMTP credentials. NO DEFAULT in code — if these are unset the Rails
# container fails fast at boot via KeyError (by design — silent
# delivery failures are the one thing a downtime monitor cannot afford).
#
# For Amazon SES: SMTP_USER_NAME is the IAM access key ID of a user
# with ses:SendEmail / ses:SendRawEmail; SMTP_PASSWORD is the SES
# SMTP password derived from that IAM user's secret access key via
# the SES signing algorithm (NOT the IAM secret itself — they are
# different values). See docs/decisions/pr-0021-kamal-deploy.md.
SMTP_USER_NAME=
SMTP_PASSWORD=

# --- Slice 3: mailer sender address ------------------------------------

# `From:` address on all outbound mail. Read in:
#   app/mailers/application_mailer.rb
# Default in code is "dorm-guard@dorm-guard.com". Must belong to a
# domain verified in Mailgun or delivery events will be rejected.
DORM_GUARD_MAIL_FROM=

# --- Slice 4: Kamal registry authentication ----------------------------

# DigitalOcean Container Registry access token. Used as BOTH the
# registry username AND password (DOCR auth model). Referenced in:
#   config/deploy.yml:registry.username / registry.password
# Generate via `doctl auth init` + `doctl registry login`. Rotate by
# issuing a new token in DigitalOcean's control panel.
KAMAL_REGISTRY_PASSWORD=

# ----------------------------------------------------------------------
# NOT env vars — but also required before `kamal setup`:
#
# 1. config/deploy.yml has two placeholder tokens that must be edited
#    by hand (they are NOT ENV-substituted by Kamal):
#      - `registry.server: registry.digitalocean.com/REPLACE-DOCR-NAMESPACE`
#      - `servers.web: [REPLACE-DROPLET-IP]`
#    Grep for `REPLACE-` in config/deploy.yml before every deploy.
#
# 2. DNS: dorm-guard.com A record must point at the droplet IP before
#    `kamal setup` so Let's Encrypt can issue a cert.
#
# 3. Mailgun: the sending domain must be verified in Mailgun before
#    Slice 7's smoke test — unverified domains land in sandbox mode
#    and only deliver to pre-authorized recipients.
# ----------------------------------------------------------------------

