# Secrets defined here are available for reference under registry/password,
# env/secret, builder/secrets, and accessories/*/env/secret in
# config/deploy.yml. All secrets must come from a password manager, ENV,
# or a file — NEVER raw credentials. This file is safe for git.
#
# dorm-guard's production deploy sources a local .env file (gitignored,
# see .env.example for the schema). CI's deploy workflow writes a .env
# with the same schema from GitHub repo secrets so laptop and runner
# are schema-symmetric.
#
# Adding a required deploy var to config/deploy.yml without a matching
# line in .env.example is a process violation. See:
#   memory/feedback_enforce_constraints_in_config.md

# Source the local .env file so every KEY in .env is exported to this
# shell, then unset the auto-export so later lines don't leak.
#
# Kamal sources .kamal/secrets from the Rails root (where deploy.yml
# lives), so .env is reachable at the same relative path. Using a
# plain `source .env` here is correct because kamal's CWD at source
# time is the repo root; an earlier version used $(dirname "$0") but
# $0 is the parent shell name when a script is sourced, not the
# script path, so that form silently resolved to a wrong directory
# and every re-exported secret ended up empty.
set -a
source .env 2>/dev/null || true
set +a

# RAILS_MASTER_KEY: on the laptop, cat config/master.key (same as the
# Rails 8 scaffold default). In CI, the deploy workflow writes
# RAILS_MASTER_KEY directly into .env from a repo secret and this
# `cat` is a no-op overwrite of the already-set value.
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || echo "${RAILS_MASTER_KEY}")

# Re-export deploy secrets that Kamal reads by name from this file.
# Each line exists because the same-named var is referenced from
# config/deploy.yml's env.secret or registry.password block.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}
SMTP_USER_NAME=${SMTP_USER_NAME}
SMTP_PASSWORD=${SMTP_PASSWORD}
DORM_GUARD_ALERT_TO=${DORM_GUARD_ALERT_TO}
