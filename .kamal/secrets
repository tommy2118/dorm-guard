# Secrets defined here are available for reference under registry/password,
# env/secret, builder/secrets, and accessories/*/env/secret in
# config/deploy.yml. All secrets must come from a password manager, ENV,
# or a file — NEVER raw credentials. This file is safe for git.
#
# Kamal parses this file line-by-line as `KEY=expression` pairs. The
# right-hand side of each line is evaluated as a shell command
# (effectively `sh -c "expression"`), and the stdout becomes KEY's
# value. **This file is NOT executed as a single shell script** —
# statements like `set -a`, `source`, or `function definitions` are
# SILENTLY IGNORED because they don't match the `KEY=value` shape.
#
# This was learned the hard way in Slices 5F and 5G — both tried to
# put a shared `source .env` at the top of the file. Both silently
# failed because kamal never executes that line.
#
# To pull values from a local `.env` file (gitignored, see
# `.env.example` for the schema), each secret line sources `.env` in
# its OWN subshell via the POSIX `.` command and then echoes the
# target variable. CI's deploy workflow writes `.env` from GitHub
# repo secrets so laptop and runner stay schema-symmetric.
#
# Adding a required deploy var to config/deploy.yml without a
# matching line in .env.example is a process violation. See
# memory/feedback_enforce_constraints_in_config.md.

# Master key reads directly from config/master.key on the laptop.
# In CI the master key is written into .env (or the environment)
# from a GitHub repo secret, and this cat falls back to whatever
# is already in RAILS_MASTER_KEY if the file is missing.
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || echo "${RAILS_MASTER_KEY}")

# Each secret below sources .env in its own subshell and echoes the
# target value. The subshell isolates .env's env vars from spilling
# into sibling lines — each line is fully self-contained.
#
# CRITICAL: the `\$VAR` inside the $(...) must be escaped. Kamal's
# dotenv parser runs a variable-substitution pass BEFORE shell-
# executing the command, and unescaped `$VAR` would get replaced
# with Kamal's own process env value (empty) before the subshell
# ever ran. Escaping with a backslash passes the literal `$VAR`
# through to the shell, which then expands it against the
# subshell's own env (populated by `. ./.env`).
KAMAL_REGISTRY_PASSWORD=$(. ./.env 2>/dev/null; echo "\$KAMAL_REGISTRY_PASSWORD")
SMTP_USER_NAME=$(. ./.env 2>/dev/null; echo "\$SMTP_USER_NAME")
SMTP_PASSWORD=$(. ./.env 2>/dev/null; echo "\$SMTP_PASSWORD")
DORM_GUARD_ALERT_TO=$(. ./.env 2>/dev/null; echo "\$DORM_GUARD_ALERT_TO")
